{
  "name": "ws-research-connect-ghc",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/ws-research-connect-ghc",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "pnpmVersion": "latest"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "bierner.markdown-mermaid",
        "ms-playwright.playwright",
        "bradlc.vscode-tailwindcss",
        "mongodb.mongodb-vscode"
      ],
      "settings": {
        "dotnet.defaultSolution": "disable"
      }
    }
  },

  // ポートフォワーディング
  // 5173: Frontend (Vite dev server)
  // 8000: Backend (FastAPI)
  // 27017: MongoDB
  // 9323: Playwright HTML report
  "forwardPorts": [5173, 8000, 27017, 9323],
  "portsAttributes": {
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "notify" },
    "8000": { "label": "Backend (FastAPI)", "onAutoForward": "notify" },
    "27017": { "label": "MongoDB", "onAutoForward": "silent" },
    "9323": { "label": "Playwright Report", "onAutoForward": "notify" }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteUser": "vscode"
}
